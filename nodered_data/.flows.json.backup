    {
        "id": "504e0ad9191f169c",
        "type": "function",
        "z": "a7485b0b96534c53",
        "name": "Détecteur de panne",
        "func": "const payload = msg.payload;\nconst lampId = 'node_01';\nconst anomalies = [];\n\n// Dernière commande PWM stockée\nconst lastPwm = flow.get('last_pwm_command') || { led1: 0, led2: 0, led3: 0, led4: 0 };\n\nfor (let i = 1; i <= 4; i++) {\n    const ledKey = 'led' + i;\n    const wattsReal = payload[ledKey + '_watts'] !== undefined ? payload[ledKey + '_watts'] : 0;\n    const pwmCmd = payload[ledKey + '_pwm_cmd'] !== undefined ? payload[ledKey + '_pwm_cmd'] : lastPwm[ledKey];\n\n    // Si PWM = 0, on ne détecte pas d'anomalie (LED éteinte = 0W normal)\n    if (pwmCmd === 0) continue;\n\n    const expectedW = (pwmCmd / 100) * 17.5;\n\n    // Protection division par zéro\n    if (expectedW === 0) continue;\n\n    const anomalyScore = Math.abs(wattsReal - expectedW) / expectedW;\n\n    if (anomalyScore > 0.4) {\n        anomalies.push({\n            led: ledKey,\n            pwmCmd: pwmCmd,\n            wattsReal: wattsReal,\n            expectedW: expectedW,\n            anomalyScore: anomalyScore.toFixed(3)\n        });\n    }\n}\n\n// Mise à jour du context pour la prochaine fois\nflow.set('last_pwm_command', {\n    led1: payload.led1_pwm_cmd || lastPwm.led1,\n    led2: payload.led2_pwm_cmd || lastPwm.led2,\n    led3: payload.led3_pwm_cmd || lastPwm.led3,\n    led4: payload.led4_pwm_cmd || lastPwm.led4\n});\n\nconst totalWatts = payload.total_watts ||\n    (payload.led1_watts || 0) + (payload.led2_watts || 0) +\n    (payload.led3_watts || 0) + (payload.led4_watts || 0);\n\nmsg.payload = {\n    lampId: lampId,\n    totalWatts: totalWatts,\n    anomalies: anomalies,\n    anomalyCount: anomalies.length,\n    status: anomalies.length > 0 ? 'DEFAILLANT' : 'OK',\n    ts: Date.now()\n};\n\nmsg.anomaly = anomalies.length > 0;\nflow.set('last_total_watts', totalWatts);\nmsg.payload.led1_watts = payload.led1_watts || 0;\nmsg.payload.led2_watts = payload.led2_watts || 0;\nmsg.payload.led3_watts = payload.led3_watts || 0;\nmsg.payload.led4_watts = payload.led4_watts || 0;\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 370,
        "y": 280,
        "wires": [
            [
                "8b70635fa6e924e2",
                "4d9e68b768c3e7ca",
                "7df5a8cd491746d3"
            ]
        ]
