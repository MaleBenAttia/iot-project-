        "z": "ia-integration-flow",
        "name": "Détection Anomalie",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://192.168.100.214:5000/anomaly",
        "tls": "",
        "persist": false,
        "proxy": "",
