    {
        "id": "c8eede0af2d5f46f",
        "type": "function",
        "z": "733351c37368d0b7",
        "name": "Logique PWM",
        "func": "// === LOGIQUE PWM - VERSION FINALE ===\nconst topic = msg.topic || '';\nconst lampId = topic.split('/')[1] || 'node_01';\n\n// Récupération des dernières valeurs\nlet ldr_value = flow.get('last_ldr') || 500;\nlet pir_detected = flow.get('last_pir_detected') || false;\nlet pir_count = flow.get('last_pir_count') || 0;\n\n// Mise à jour selon le topic\nif (topic.includes('ldr')) {\n    ldr_value = msg.payload.value !== undefined ? msg.payload.value : ldr_value;\n    flow.set('last_ldr', ldr_value);\n}\nelse if (topic.includes('pir')) {\n    pir_detected = msg.payload.detected !== undefined ? msg.payload.detected : pir_detected;\n    pir_count = msg.payload.count_10min !== undefined ? msg.payload.count_10min : pir_count;\n    flow.set('last_pir_detected', pir_detected);\n    flow.set('last_pir_count', pir_count);\n}\n\n// Calcul PWM\nconst hour = new Date().getHours();\nconst isNight = (ldr_value < 80);\n\nlet pwm = 0;\nif (!isNight) {\n    pwm = 0;\n} else if (pir_detected || pir_count > 2) {\n    pwm = 100;\n} else if (hour >= 22 || hour <= 5) {\n    pwm = 20;\n} else {\n    pwm = 50;\n}\n\n// Sauvegarde pour IA\nflow.set('last_ldr', ldr_value);\nflow.set('last_pir_count', pir_count);\nflow.set('last_pir_detected', pir_detected);\nflow.set('last_pwm', pwm);\n\nmsg.payload = {\n    lampId: lampId,\n    pwm: Math.round(pwm),\n    source: \"Node-RED\",\n    isNight: isNight,\n    ldr: Math.round(ldr_value),\n    pir: pir_detected,\n    ts: Date.now()\n};\n\nmsg.topic = `smart_lighting/${lampId}/cmd/pwm`;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 740,
        "y": 280,
        "wires": [
            [
                "45016d5e6e114d3a",
                "260fd198ad0803a5",
                "de1ffaf3e7f829fc"
            ]
        ]
    },
