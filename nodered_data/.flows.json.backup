        "name": "Format TB - PWM+Capteurs",
        "func": "msg.payload = {\n    ldr_value: msg.payload.ldr,\n    pir_detected: msg.payload.pir ? 1 : 0,\n    is_night: msg.payload.isNight ? 1 : 0,\n    pwm_led1: msg.payload.pwm,\n    pwm_led2: msg.payload.pwm,\n    pwm_led3: msg.payload.pwm,\n    pwm_led4: msg.payload.pwm\n};\nreturn msg;",
