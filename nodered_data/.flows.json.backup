    {
        "id": "657e6c5b17f5d470",
        "type": "mqtt in",
        "z": "a7485b0b96534c53",
        "name": "Consommation réelle",
        "topic": "smart_lighting/+/sensors/power",
        "qos": "1",
        "datatype": "auto-detect",
        "broker": "fbacf16aa36bb4ab",
        "nl": false,
        "rap": true,
        "rh": 0,
        "inputs": 0,
        "x": 160,
