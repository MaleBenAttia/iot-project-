    {
        "id": "1bd582adf418e966",
        "type": "function",
        "z": "733351c37368d0b7",
        "name": "Format TB - PIR Zones",
        "func": "const payload = msg.payload;\nmsg.payload = {\n    pir_zone_a_detected: payload.zone === 'A' ? (payload.detected ? 1 : 0) : undefined,\n    pir_zone_a_count: payload.zone === 'A' ? payload.count_10min : undefined,\n    pir_zone_b_detected: payload.zone === 'B' ? (payload.detected ? 1 : 0) : undefined,\n    pir_zone_b_count: payload.zone === 'B' ? payload.count_10min : undefined\n};\n// Supprimer les clés undefined\nObject.keys(msg.payload).forEach(k => {\n    if (msg.payload[k] === undefined) delete msg.payload[k];\n});\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 750,
        "y": 120,
