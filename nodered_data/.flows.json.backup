    {
        "id": "7df5a8cd491746d3",
        "type": "function",
        "z": "a7485b0b96534c53",
        "name": "Format TB - Watts+Anomalie",
        "func": "const p = msg.payload;\nconst src = p; // issu du détecteur\n\n// Récupérer les watts individuels depuis le message original\n// (le détecteur de panne reçoit le payload power direct)\nmsg.payload = {\n    total_watts: p.totalWatts || 0,\n    anomaly_count: p.anomalyCount || 0,\n    lamp_status: p.status === 'DEFAILLANT' ? 1 : 0,\n    led1_watts: src.led1_watts || 0,\n    led2_watts: src.led2_watts || 0,\n    led3_watts: src.led3_watts || 0,\n    led4_watts: src.led4_watts || 0\n};\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 480,
        "y": 420,
        "wires": [
            [
                "d846ac2d9f05c224"
            ]
        ]
    },
    {
        "id": "timer-ia",
        "type": "inject",
        "z": "ia-integration-flow",
        "name": "Toutes les 30s",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "10",
        "crontab": "",
        "once": true,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "{}",
        "payloadType": "json",
        "x": 240,
        "y": 420,
        "wires": [
            [
                "get-context-data"
            ]
        ]
    },
    {
        "id": "get-context-data",
        "type": "function",
        "z": "ia-integration-flow",
        "name": "Préparer données IA",
        "func": "const hour = new Date().getHours();\nconst day_of_week = new Date().getDay();\nconst is_weekend = (day_of_week === 0 || day_of_week === 6) ? 1 : 0;\n\nconst ldr_value = flow.get('last_ldr') || 50;\nconst pir_count_10min = flow.get('last_pir_count') || 3;\nconst is_night = (ldr_value < 80) ? 1 : 0;\n\nconst pwm_command = flow.get('last_pwm') || 50;\nconst current_consumption_w = flow.get('last_total_watts') || 25;\nconst expected_consumption_w = (pwm_command / 100) * 70;\n\nmsg.payload = {\n    hour: hour,\n    day_of_week: day_of_week,\n    is_weekend: is_weekend,\n    ldr_value: ldr_value,\n    is_night: is_night,\n    pir_count_10min: pir_count_10min,\n    pwm_command: pwm_command,\n    current_consumption_w: current_consumption_w,\n    expected_consumption_w: expected_consumption_w\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 360,
        "y": 200,
        "wires": [
            [
                "http-predict",
                "http-anomaly",
                "http-cluster"
            ]
        ]
    },
    {
        "id": "http-predict",
        "type": "http request",
        "z": "ia-integration-flow",
        "name": "Prédiction PWM",
        "method": "POST",
        "ret": "obj",
        "paytoqs": "ignore",
        "url": "http://192.168.100.214:5000/predict",
        "tls": "",
        "persist": false,
        "proxy": "",
        "insecureHTTPParser": false,
        "authType": "",
        "senderr": false,
        "headers": [],
        "x": 580,
        "y": 100,
        "wires": [
            [
                "publish-prediction",
